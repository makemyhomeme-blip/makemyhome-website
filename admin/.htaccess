# Zaštita admin foldera
# Opciono: Dozvolite samo specifičnoj IP adresi
# Order Deny,Allow
# Deny from all
# Allow from 123.456.789.0

Options -Indexes

# Povećaj upload limit za slike (ChatGPT PNG slike su 3-5MB)
<IfModule mod_php.c>
  php_value upload_max_filesize 15M
  php_value post_max_size 20M
</IfModule>
<IfModule mod_php8.c>
  php_value upload_max_filesize 15M
  php_value post_max_size 20M
</IfModule>
